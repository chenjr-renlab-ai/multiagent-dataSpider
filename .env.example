# Copy this file to .env and adjust as needed.

# Redis connection
REDIS_URL=redis://redis:6379

# PostgreSQL connection (asyncpg dialect)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/spiderdb

# PostgreSQL superuser password (used by docker-compose postgres service)
POSTGRES_PASSWORD=postgres

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
